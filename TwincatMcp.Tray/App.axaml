<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TwincatMcp.Tray.App"
             RequestedThemeVariant="Default">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Button">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Application.Styles>

  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="{Binding TrayIcon}"
                ToolTipText="{Binding TrayToolTip}"
                Command="{Binding ShowSettingsCommand}">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Start server" Command="{Binding StartServerCommand}" />
            <NativeMenuItem Header="Stop server" Command="{Binding StopServerCommand}" />
            <NativeMenuItem Header="Open settings" Command="{Binding ShowSettingsCommand}" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Exit" Command="{Binding ExitCommand}" />
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>
</Application>
